{
  "family": "sai-embedding-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::453875231722:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::453875231722:role/saiEmbeddingTaskRole",
  "containerDefinitions": [
    {
      "name": "sai-embedding-worker",
      "image": "453875231722.dkr.ecr.us-east-1.amazonaws.com/sai-embedding-service:latest",
      "essential": true,
      "command": ["python", "-m", "app.worker"],
      "environment": [
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "EMBEDDING_QUEUE_URL", "value": "https://sqs.us-east-1.amazonaws.com/453875231722/sai-embedding-queue" },
        { "name": "MISTRAL_EMBED_MODEL", "value": "mistral-embed" },
        { "name": "EMBEDDING_BATCH_SIZE", "value": "32" },
        { "name": "EMBEDDING_DIMENSION", "value": "1024" },
        { "name": "SQS_WAIT_TIME_SECONDS", "value": "20" },
        { "name": "SQS_VISIBILITY_TIMEOUT_SECONDS", "value": "900" },
        { "name": "POSTGRES_HOST", "value": "database-1.ckvcqmcakbxd.us-east-1.rds.amazonaws.com" },
        { "name": "POSTGRES_PORT", "value": "5432" },
        { "name": "POSTGRES_DB", "value": "sairag" },
        { "name": "POSTGRES_USER", "value": "postgres" },
        { "name": "POSTGRES_SSLMODE", "value": "require" },
        { "name": "LOG_LEVEL", "value": "INFO" }
      ],
      "secrets": [
        {
          "name": "MISTRAL_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:453875231722:secret:sai/mistral/api-key"
        },
        {
          "name": "POSTGRES_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:453875231722:secret:sai/rds/postgres-password"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sai-embedding-worker",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
